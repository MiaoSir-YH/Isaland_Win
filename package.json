{
  "name": "vibe-island-windows",
  "version": "0.1.0",
  "description": "Private Windows prototype of an AI agent status island.",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "package:dir": "npm run build && electron-builder --win --dir --x64",
    "package:zip": "npm run build && electron-builder --win zip --x64",
    "package": "npm run build && electron-builder --win nsis --x64",
    "test": "vitest run",
    "test:watch": "vitest",
    "hook": "node scripts/vibe-island-hook.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.468.0",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "dev.vibeisland.windows",
    "productName": "Vibe Island",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MiaoSir-YH",
        "repo": "Island_Win"
      }
    ],
    "files": [
      "out/**",
      "scripts/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
